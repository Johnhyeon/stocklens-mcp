{
  "manifest_version": "0.4",
  "name": "stocklens-mcp",
  "display_name": "StockLens",
  "version": "0.3.1",
  "description": "한국(네이버)·미국(Yahoo) 주식 + ETF MCP 서버. 차트·수급·재무·실적·배당·스크리닝·Excel 스냅샷으로 Claude에서 바로 분석.",
  "author": {
    "name": "Johnhyeon"
  },
  "icons": [
    {"src": "assets/icon.png",       "size": "512x512", "theme": "dark"},
    {"src": "assets/icon-light.png", "size": "512x512", "theme": "light"}
  ],
  "homepage": "https://github.com/Johnhyeon/stocklens-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/Johnhyeon/stocklens-mcp"
  },
  "license": "MIT",
  "keywords": [
    "stock",
    "mcp",
    "claude",
    "naver",
    "korea",
    "finance",
    "stocklens",
    "investment"
  ],
  "server": {
    "type": "uv",
    "entry_point": "stock_mcp_server/server.py",
    "mcp_config": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${__dirname}",
        "stock_mcp_server/server.py"
      ]
    }
  },
  "compatibility": {
    "platforms": ["darwin", "linux", "win32"],
    "runtimes": {
      "python": ">=3.11"
    }
  }
}
